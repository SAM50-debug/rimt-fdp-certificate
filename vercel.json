{
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "{data/**,assets/**,src/assets/fonts/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|@vite/|@fs/|@react-refresh|node_modules/|src/|assets/)[^.]*)",
      "destination": "/index.html"
    }
  ]
}
